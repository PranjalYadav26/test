                    updateResidentialAddrValidity.add(true);
                  }

                  if (updateResidentialAddrValidity.contains(true)) {
                    setContactListForUpd.add(c);
                  }
                }
              }
              // Group Member Accounts
              for (Account a : gmAllAccounts) {
                // * Postal Address
                if (a.ShippingStreet != street) {
