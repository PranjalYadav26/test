@AuraEnabled
public static Contact getContactForMailing(Id contactId) {
   
    
    Contact result = [SELECT Id, MailingStreet, MailingCity, MailingState, MailingPostalCode, MailingCountry,
                             OtherStreet, OtherCity, OtherState, OtherPostalCode, OtherCountry,
                             Physical_Address__c,
                             Account.ShippingStreet, Account.ShippingCity, Account.ShippingState, 
                             Account.ShippingPostalCode, Account.ShippingCountry
                      FROM Contact 
                      WHERE Id = :contactId 
                      LIMIT 1];
  
    
    return result;
}


@AuraEnabled
public static Contact saveContactMailingAddress(Id contactId, String street, String city, String state, String postcode, String country) {

    // Query the record before update to see current state
    Contact beforeUpdate = [SELECT MailingStreet, MailingCity, MailingState, MailingPostalCode, MailingCountry 
                           FROM Contact WHERE Id = :contactId];
   
    
    Contact contact = new Contact(Id = contactId);
    
    // Handle empty strings as null for proper database storage
    contact.MailingStreet = String.isNotBlank(street) ? street : null;
    contact.MailingCity = String.isNotBlank(city) ? city : null;
    contact.MailingState = String.isNotBlank(state) && !state.equals('1') && !state.equals('Please Select') ? state : null;
    contact.MailingPostalCode = String.isNotBlank(postcode) ? postcode : null;
    contact.MailingCountry = String.isNotBlank(country) ? country : null;
    
    
    try {
        update contact;
        System.debug('UPDATE SUCCESSFUL');
        
        // Query again after update to verify
        Contact afterUpdate = [SELECT MailingStreet, MailingCity, MailingState, MailingPostalCode, MailingCountry 
                              FROM Contact WHERE Id = :contactId];
        System.debug('AFTER UPDATE - State: ' + afterUpdate.MailingState + ', Country: ' + afterUpdate.MailingCountry);
        
    } catch (Exception e) {
        System.debug('UPDATE FAILED: ' + e.getMessage());
        throw e;
    }
    
    return getContactForMailing(contactId);
}


