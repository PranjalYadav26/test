    getCampaignDetails : function(component){
        component.set('v.showSpinner',true);
        var action = component.get('c.getCampaignInfo');
        action.setParams({
            cId : component.get('v.recordId')
        });
            action.setCallback(this, function(response) {
            var state = response.getState();
            if (state === 'SUCCESS') {
                var result = JSON.parse(response.getReturnValue());
                var camp = result.campaign;
                console.log('Current Campaign ===>',camp);
                if (camp != undefined) {
                    var campJson = {
                        'Id': camp.Id,
                        'title': camp.Name,
                        'Name': camp.Name,
                        'Status' : camp.Status
                    }
                    component.set('v.taskRelatedToCampaign',campJson);
                    component.set('v.cmRecordTypeName',camp.CampaignMemberRecordType.DeveloperName);
                    this.initTableColumns(component,component.get('v.isUpdateAssignee'));
                    this.loadFilters(component);
                    this.getCampaignMembers(component,null);
                }
            }
        });
        $A.enqueueAction(action);
    },

