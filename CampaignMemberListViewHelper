    displayCM : function(component){
        var currentPage = component.get('v.page');
        var pagifiedData = component.get('v.pagifiedCmpMembers');
        console.log('Current', currentPage);
        var data = this.processCampaignMemberData(component,pagifiedData[currentPage-1]);
        component.set('v.cmpMembers',data);
        component.set('v.showSpinner',false);
    },

    pagination : function(component){
        console.log('commence pagination..');
        var size = component.get('v.pageSize');
        var data = component.get('v.allData');
        if (data.length === 0){
            const data = [];
            component.set('v.cmpMembers',data);
            component.set('v.showSpinner',false);
        }
        else {
        console.log('Page max Size: ' ,size);
        const pagified_arr = [];
        let index=0;
        while(index < data.length){
            pagified_arr.push(data.slice(index, size + index));
            index = index + size;
        }
        component.set('v.pagifiedCmpMembers',pagified_arr);
        component.set('v.totalPages', component.get('v.pagifiedCmpMembers').length);
        this.displayCM(component);
        }
    },
    
    getCampaignMembers : function(component,filterCondi){
        console.log('========= Getting campaign Members =========');
        console.log('Filters are',filterCondi);
        var action = component.get('c.getCM');
		
        action.setParams({
            campId : component.get('v.recordId'),
            isUpdateAssignee : component.get('v.isUpdateAssignee'),
            cmRecordType : component.get('v.cmRecordTypeName'),
            filters : filterCondi
        });
        
        action.setCallback(this, function(response){
            var state = response.getState();
            console.log(state,' STATE');
            if (state==='SUCCESS'){
                var results = response.getReturnValue();
                console.log('get CM results: ', results);
                let totalData = results.total;
                let displayTotal = results.cm.length;
                component.set('v.totalNoOfCampaignMembers',totalData);
                component.set('v.totalAllocatedMembers',results.allocated);             
                var alldata = [];
                if( displayTotal != 0){      	
                    alldata = results.cm; 
                    console.log('============ received data =============');
                    console.log('total data received: ', displayTotal);                     
                }
                component.set('v.cmpMembers',[]);
                component.set('v.allData',alldata);
                component.set('v.allDataTemp',alldata);//used for search functionality.
                this.pagination(component);                
            }
            else  if(state==='ERROR'){
                var msg = response.getError();
                if (msg){
                    console.log(msg);
                }
                component.set('v.showSpinner',false);
                this.showToast(component,'Campaign Members','Something went wrong. Failed to retrieve campaign member records.','Error');
            }
        });
        $A.enqueueAction(action);
    },

