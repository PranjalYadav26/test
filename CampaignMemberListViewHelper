    prepareCallLogFields: function(component,row){      
        let firstName = row.ContactId__r.FirstName;
        let lastName = row.ContactId__r.LastName;
        let date = new Date();
        let dt = date.getDate()+'-'+(date.getMonth()+1)+'-'+date.getFullYear()+' '+date.getHours() + ":"
		+ date.getMinutes() + ":" + date.getSeconds();

        var subjectmsg = dt + '-Campaign Call-';
        if(firstName!=undefined){
		subjectmsg +=firstName+' ';
        }
        if(lastName!=undefined){
        subjectmsg +=lastName;
        }                
        //default values for task/Activity (call log) creation
        var callLog = {
            'Subject' : subjectmsg,
            'Direction__c' :'Outbound',
            'ContactId' : row.ContactId__c,
            'Outcome__c' : '',
            'Financial_Account__c' : row.Financial_Account__r_FinServ__FinancialAccountNumber__c,
            'Contact' : row.ContactId__r.Name,
            'campaignMemberId': row.id
        }
        console.log('Campaign Member Id:', row.id);
        component.set('v.callLog',callLog);
    },

    callLogASM : function(component,contactId){
        var action = component.get('c.checkActivityRecordType');
        action.setParams({
            recordType : 'ASM'
        });
        
        action.setCallback(this, function(response){
            var state = response.getState();
            if ( state ==='SUCCESS'){
                var results = response.getReturnValue();
                var createRecord = $A.get("e.force:createRecord");
                    const campId = component.get('v.taskRelatedToCampaign.Id');
                const subject = component.get('v.taskRelatedToCampaign.Name');
                var defaultField = {
                    'WhatId' : campId,
                    //'WhoId' : contactId,
                    'CallObject' : contactId,
                    'Subject' : subject
                };       
                createRecord.setParams({
                    'entityApiName' : 'Task',
                    'recordTypeId' : results,
                    'defaultFieldValues' : defaultField
                });
                createRecord.fire();             
            }
        });
        $A.enqueueAction(action);
    },
    
