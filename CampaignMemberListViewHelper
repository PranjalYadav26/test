    deleteZeroAttempt: function(component) {
        var action = component.get("c.deleteZeroAttemptRecs");
        action.setParams({ campId : component.get('v.recordId') });

        action.setCallback(this, function(response) {
            var state = response.getState();
            if (state === "SUCCESS") {
                document.getElementById('filterErrorMsg').innerHTML='';
				this.clearFilter(component);
        		this.resetPage(component);
        		this.getCampaignMembers(component,null);
            }
            else if (state === "ERROR") {
                var errors = response.getError();
                if (errors) {
                    if (errors[0] && errors[0].message) {
                        console.log("Error message: " + 
                                 errors[0].message);
                    }
                } else {
                    console.log("Unknown error");
                }
            }
        });

        $A.enqueueAction(action);
    },
    
