  @AuraEnabled
  public static FinServ__FinancialAccount__c[] getFinancialAccounts(Id accountId) {
    List<FinServ__FinancialAccount__c> orderedAccounts = new List<FinServ__FinancialAccount__c>();
    try {
      //SFP-2788 Jerry
      String profileName = UtilityClass.getUserInfo('PROFILENAME');
      String whereQueryFAR = null;
      String whereQueryFA = null;
      String productAS = ConstantsFinancialAccount.FA_PRODUCT_CODE_AS;
      String productIL = ConstantsFinancialAccount.FA_PRODUCT_CODE_IL;

      if (profileName.contains('~External')) {
        whereQueryFAR = '(FinServ__RelatedAccount__c =: accountId OR SCV_RelatedAccount__c =: accountId) '
            + 'AND FinServ__Role__c = \'Primary Life Insured\' '
            + 'AND FinServ__FinancialAccount__r.Product_System_Code__c = \'TZ\''
            + 'AND FinServ__FinancialAccount__r.FinServ__Status__c = \'Active\'';

        whereQueryFA = '(FinServ__Status__c = \'Active\' '
            + 'AND (FinServ__PrimaryOwner__c = :accountId OR SCV_PrimaryOwner__c = :accountId) '
            + 'AND (AMP_Product__c = true OR '
            + 'Product_System_Code__c = :productAS OR Product_System_Code__c = :productIL)) '
            + 'OR Id IN: faIds ORDER BY LastModifiedDate DESC';
      } else {
        //   whereQueryFAR = '(FinServ__RelatedAccount__c =: accountId OR SCV_RelatedAccount__c =: accountId) '
        whereQueryFAR = '(FinServ__RelatedAccount__c =: accountId) '
            + 'AND FinServ__Role__c = \'Primary Life Insured\' '
            + 'AND FinServ__FinancialAccount__r.Product_System_Code__c = \'TZ\'';

        //   whereQueryFA = '((FinServ__PrimaryOwner__c=:accountId OR SCV_PrimaryOwner__c = :accountId) '
        //               + 'AND AMP_Product__c = true) '
        //   + 'OR Id IN: faIds ORDER BY LastModifiedDate DESC';

        whereQueryFA = 'FinServ__PrimaryOwner__c=:accountId  '
            + 'ORDER BY LastModifiedDate DESC';
      }

      String queryStringFAR = 'SELECT FinServ__FinancialAccount__r.Id FROM FinServ__FinancialAccountRole__c WHERE ' + whereQueryFAR;

      String queryStringFA = 'SELECT Id, Name, FinServ__PrimaryOwner__c, FinServ__ProductName__r.Name, FinServ__Status__c, ' +
          'Product_System__c, Product_System_Code__c, FinServ__FinancialAccountNumber__c, FinServ__Address1__c, ' +
          'FinServ__City__c, FinServ__State__c, Suburb__c, FinServ__Country__c, FinServ__PostalCode__c, ' +
          'Address_WADI__c, FinServ__FinancialAccountType__c, Address_DPID__c FROM FinServ__FinancialAccount__c ' +
          'WHERE ' + whereQueryFA;




      Set<Id> faIds = new Set<Id>();
      for (FinServ__FinancialAccountRole__c rec : Database.query(queryStringFAR)) {
        faIds.add(rec.FinServ__FinancialAccount__r.Id);
      }
      system.debug(queryStringFA);
      List<FinServ__FinancialAccount__c> financialAccounts = Database.query(queryStringFA);


      List<FinServ__FinancialAccount__c> active = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> pending = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> lodged = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> closed = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> ASandIL = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> other = new List<FinServ__FinancialAccount__c>();
      for (FinServ__FinancialAccount__c finAct : financialAccounts) {
        if (finAct.FinServ__Status__c == 'Active') {
          if (finAct.Product_System_Code__c == productAS
              || finAct.Product_System_Code__c == productIL) {
            ASandIL.add(finAct);
          } else {
            active.add(finAct);
          }
        } else if (finAct.FinServ__Status__c == 'Pending') {
          pending.add(finAct);
        } else if (finAct.FinServ__Status__c == 'Lodged') {
          lodged.add(finAct);
        } else if (finAct.FinServ__Status__c == 'Closed') {
          closed.add(finAct);
        } else {
          other.add(finAct);
        }
      }
      orderedAccounts.addAll(active);
      orderedAccounts.addAll(other);
      orderedAccounts.addAll(pending);
      orderedAccounts.addAll(lodged);
      orderedAccounts.addAll(closed);
      orderedAccounts.addAll(ASandIL);
    } catch (Exception e) {
      logUtilityCapture.insertErrorLog(e);

    }
      system.debug('UB01' + orderedAccounts);
    return orderedAccounts;
  }

  @AuraEnabled
  public static void saveAddressConsolidated(Id accountRecordId, Id contactRecordId, String street, String suburb, String city, String state, String postcode, String country, Boolean invalid, string DPID,
      Boolean isResidentialChecked, Boolean isPostalChecked, Boolean isBusinessChecked, List<Id> finAccountIds) {

    Contact contact = new Contact();
    Account account = new Account();
    List<FinServ__FinancialAccount__c> fasUpdate = new List<FinServ__FinancialAccount__c>();

    if (isResidentialChecked) {
      UtilityClass.isResidentialChecked = true;
      contact.Id = contactRecordId;
      contact.OtherStreet = street;
      contact.Residential_Suburb__c = suburb;
      contact.OtherCity = city;
      contact.OtherState = state;
      contact.OtherPostalCode = postcode;
      contact.OtherCountry = country;
      contact.Residential_Address_Invalid__c = invalid;
      contact.Residential_Address_Delivery_Point_Id__c = DPID;
    }

    if (isPostalChecked) {
      UtilityClass.isPostalChecked = true;
      account.Id = accountRecordId;
      account.ShippingStreet = street;
      account.Postal_Suburb__c = suburb;
      account.ShippingCity = city;
      account.ShippingState = state;
      account.ShippingPostalCode = postcode;
      account.ShippingCountry = country;
      account.Postal_Address_Invalid__c = invalid;
      account.Postal_Address_Delivery_Point_Id__c = DPID;
    }
    if (isBusinessChecked) {
      UtilityClass.isBusinessChecked = true;
      account.Id = accountRecordId;
      account.BillingStreet = street;
      account.Business_Suburb__c = suburb;
      account.BillingCity = city;
      account.BillingState = state;
      account.BillingPostalCode = postcode;
      account.BillingCountry = country;
      account.Business_Address_Invalid__c = invalid;
      account.Business_Delivery_Point_Id__c = DPID;
    }

    for (Id faId : finAccountIds) {
      FinServ__FinancialAccount__c finAcct = new FinServ__FinancialAccount__c();
      finAcct.Id = faId;
      finAcct.FinServ__Address1__c = street;
      finAcct.Suburb__c = suburb;
      finAcct.FinServ__City__c = city;
      finAcct.FinServ__State__c = state;
      finAcct.FinServ__PostalCode__c = postcode;
      finAcct.FinServ__Country__c = country;
      //finAcct.Address_Invalid__c = invalid; SFP-35055
      finAcct.Address_WADI__c = invalid;
      finAcct.Address_DPID__c = DPID;
      fasUpdate.add(finAcct);
    }

    try {

      if (isResidentialChecked) {
        resetStaticVariables();
        update contact;
      }

      if (isPostalChecked || isBusinessChecked) {
        resetStaticVariables();
        update account;
      }

      if (fasUpdate.size() > 0) update fasUpdate;

    } catch (Exception e) {
       logUtilityCapture.insertErrorLog(e);

    }

  }
