                  updatePostBusAddrValidity.add(true);
                }
                if (a.Postal_Address_Invalid__c != invalid) {
                  a.Postal_Address_Invalid__c = invalid;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Postal_Address_Delivery_Point_Id__c != DPID) {
                  a.Postal_Address_Delivery_Point_Id__c = DPID;
                  updatePostBusAddrValidity.add(true);
                }

                // * Business Address
                if (a.BillingStreet != street) {
                  a.BillingStreet = street;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Suburb__c != suburb) {
                  a.Business_Suburb__c = suburb;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingCity != city) {
                  a.BillingCity = city;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingState != state) {
                  a.BillingState = state;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingPostalCode != postcode) {
                  a.BillingPostalCode = postcode;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingCountry != country) {
                  a.BillingCountry = country;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Address_Invalid__c != invalid) {
                  a.Business_Address_Invalid__c = invalid;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Delivery_Point_Id__c != DPID) {
                  a.Business_Delivery_Point_Id__c = DPID;
                  updatePostBusAddrValidity.add(true);
                }

                if (updatePostBusAddrValidity.contains(true)) {
                  setAccountListForUpd.add(a);
                }
              }

              // UPDATE RESIDENTIAL ADDRESSES
              if (setContactListForUpd.size() > 0) {
                update setContactListForUpd;
              }
              resetStaticVariables();
              // UPDATE POSTAL, BUSINESS ADDRESSES
              if (setAccountListForUpd.size() > 0) {
                update setAccountListForUpd;
              }
            }
          }
        }
      }
    } catch (Exception e) {
      logUtilityCapture.insertErrorLog(e);
    }
  }

  @AuraEnabled
  public static void bulkUpdateSpecificAddresses(Map<Id, String> getGMAddressMap, String street, String suburb, String city, String state, String postcode, String country, Boolean invalid, string DPID) {
    try {
        system.debug('getGMAddressMap::'+getGMAddressMap);
      if (!getGMAddressMap.isEmpty()) {
        Set<Id> gmAccountIds = new Set<Id>();
        Set<Id> gmContactIds = new Set<Id>();
        List<Contact> setContactListForUpd = new List<Contact>();
        List<Account> setAccountListForUpd = new List<Account>();
        List<Boolean> updateResidentialAddrValidity = new List<Boolean>();
        List<Boolean> updatePostBusAddrValidity = new List<Boolean>();

        for (Id gmId : getGMAddressMap.keySet()) {
          String sobjectName = gmId.getSObjectType().getDescribe().getName();
          if (sobjectName == 'Account') {
            gmAccountIds.add(gmId);
          } else if (sobjectName == 'Contact') {
            gmContactIds.add(gmId);
          }
        }
        if (!gmAccountIds.isEmpty()) {
          List<Account> gmAccounts = [
              SELECT Id, Name, RecordType.Name, Postal_Address_Delivery_Point_Id__c, Business_Delivery_Point_Id__c,
                  FinServ__PrimaryContact__c, BillingCity, BillingCountry, BillingPostalCode, BillingState, BillingStreet,
                  Business_Suburb__c, Business_Address_Invalid__c, Business_Addressee_Name__c, ShippingCity, ShippingCountry,
                  ShippingPostalCode, ShippingState, ShippingStreet, Postal_Suburb__c, Postal_Address_Invalid__c,
                  Postal_Addressee_Name__c
              FROM Account
              WHERE Id IN:gmAccountIds
          ];

          if (gmAccounts.size() > 0) {
            for (Account a : gmAccounts) {
              // * Postal Address
              if (getGMAddressMap.get(a.Id).contains('Postal')) {
                if (a.ShippingStreet != street) {
                  a.ShippingStreet = street;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Postal_Suburb__c != suburb) {
                  a.Postal_Suburb__c = suburb;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.ShippingCity != city) {
                  a.ShippingCity = city;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.ShippingState != state) {
                  a.ShippingState = state;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.ShippingPostalCode != postcode) {
                  a.ShippingPostalCode = postcode;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.ShippingCountry != country) {
                  a.ShippingCountry = country;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Postal_Address_Invalid__c != invalid) {
                  a.Postal_Address_Invalid__c = invalid;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Postal_Address_Delivery_Point_Id__c != DPID) {
                  a.Postal_Address_Delivery_Point_Id__c = DPID;
                  updatePostBusAddrValidity.add(true);
                }
              }

              // * Business Address
              if (getGMAddressMap.get(a.Id).contains('Business')) {
                if (a.BillingStreet != street) {
                  a.BillingStreet = street;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Suburb__c != suburb) {
                  a.Business_Suburb__c = suburb;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingCity != city) {
                  a.BillingCity = city;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingState != state) {
                  a.BillingState = state;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingPostalCode != postcode) {
                  a.BillingPostalCode = postcode;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.BillingCountry != country) {
                  a.BillingCountry = country;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Address_Invalid__c != invalid) {
                  a.Business_Address_Invalid__c = invalid;
                  updatePostBusAddrValidity.add(true);
                }
                if (a.Business_Delivery_Point_Id__c != DPID) {
                  a.Business_Delivery_Point_Id__c = DPID;
                  updatePostBusAddrValidity.add(true);
                }
              }

              if (updatePostBusAddrValidity.contains(true)) {
                setAccountListForUpd.add(a);
              }
            }
          }
        }

        if (!gmContactIds.isEmpty()) {
          List<Contact> gmContacts = [
              SELECT AccountId, Account.RecordType.Name, OtherStreet, Residential_Suburb__c, OtherCity, OtherState, OtherPostalCode, OtherCountry,
                  Residential_Address_Invalid__c, Residential_Address_Delivery_Point_Id__c
              FROM Contact
              WHERE Id IN:gmContactIds
          ];

          if (gmContacts.size() > 0) {
            for (Contact c : gmContacts) {
              // * Residential Address
              if (getGMAddressMap.get(c.Id).contains('Residential')) {
                if (c.OtherStreet != street) {
                  c.OtherStreet = street;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.Residential_Suburb__c != suburb) {
                  c.Residential_Suburb__c = suburb;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.OtherCity != city) {
                  c.OtherCity = city;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.OtherState != state) {
                  c.OtherState = state;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.OtherPostalCode != postcode) {
                  c.OtherPostalCode = postcode;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.OtherCountry != country) {
                  c.OtherCountry = country;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.Residential_Address_Invalid__c != invalid) {
                  c.Residential_Address_Invalid__c = invalid;
                  updateResidentialAddrValidity.add(true);
                }
                if (c.Residential_Address_Delivery_Point_Id__c != DPID) {
                  c.Residential_Address_Delivery_Point_Id__c = DPID;
                  updateResidentialAddrValidity.add(true);
                }

                if (updateResidentialAddrValidity.contains(true)) {
                  setContactListForUpd.add(c);
                }
              }
            }
          }
        }
        // UPDATE RESIDENTIAL ADDRESSES
        if (setContactListForUpd.size() > 0) {
          update setContactListForUpd;
        }
        resetStaticVariables();
        // UPDATE POSTAL, BUSINESS ADDRESSES
        if (setAccountListForUpd.size() > 0) {
          update setAccountListForUpd;
        }
      }
    } catch (Exception e) {
      logUtilityCapture.insertErrorLog(e);
    }
  }


