		set<Id> campMemberIds = new set<Id>();
		Set<String> contCampMembers = new Set<String>();
		//Map<String, CampaignMember__c> mapContToCampMembers = new Map<String, CampaignMember__c>();
		for (Task taskObj : newTasks){
			campMemberIds.add(taskObj.CampaignMember__c);
			//system.debug('Contact id :' + taskObj.WhoId);
			//system.debug('campaign id' + taskObj.WhatId);
			//system.debug('record type id' + taskObj.recordtypeId);

			//Record type check for call log & Related to Campaign object & Contact need to be selected.
			/*if ((taskObj.recordtypeId == ConstantsTask.TASK_RT_CALL_LOG || taskObj.recordtypeId == ConstantsTask.TASK_RT_ASM) && taskObj.WhatId != Null && String.valueOf(taskObj.WhatId).startsWith('701') && taskObj.WhoId != Null && String.valueOf(taskObj.WhoId).startsWith('003')){
				//campIds.add(taskObj.WhatId);
                //if(taskObj.recordtypeId == ConstantsTask.TASK_RT_CALL_LOG){
