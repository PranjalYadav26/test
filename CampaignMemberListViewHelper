    navigateToSubTab: function(component, subTabRecId) {
        var workspaceAPI = component.find('workspace');
        var recID = component.get('v.recordId');
        var isConsoleNav = component.get('v.isConsoleNav');
        if(isConsoleNav == true){
            workspaceAPI.openTab({
                url: '#/sObject/' +recID+'/view',
                focus: true
            }).then(function(response) {
                workspaceAPI.openSubtab({
                    parentTabId: response,
                    url: '#/sObject/'+subTabRecId+'/view',
                    focus: true,
                    recordId: subTabRecId
                });
            }).catch(function(error) {
                console.log(error);
            });
        } else {
            window.open('/' + subTabRecId);
        }
    },

    sortData: function(component) {
        let data = component.get('v.allData');
        let sortedBy = component.get('v.sortedBy');
        let sortDirection = component.get('v.sortDirection');
        data.sort((a,b) => {
			let x = 0
            //get field values to compare, add null to consider nulls
            let value1 = a[sortedBy] || '';
            let value2 = b[sortedBy] || '';
            value1 = (value1).toString().toLowerCase();
			value2 = (value2).toString().toLowerCase();
            if (sortDirection == 'asc') {
            	x = value1 < value2 ? -1 : value1 > value2 ? 1 : 0;
      		} else {
                x = value2 < value1 ? -1 : value2 > value1 ? 1 : 0;
            }
           return x;
        });
        component.set('v.allData', data);
        this.pagination(component);
    },

    showToast : function(component,title,message,type,mode){
		// TYPE ACCEPTED ARE , INFO, SUCCESS, WARNING, ERROR
        // MODE ACCEPTED ARE , dismissible, pester, sticky
        var toastEvent = $A.get('e.force:showToast');
