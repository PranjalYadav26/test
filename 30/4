  @AuraEnabled
  public static List<SObject> getGroupMemberData(Id getAccountID, String retrievalScenario) {
    List<SObject> getGMData = new List<SObject>();
    try {
      if (getAccountID != null) {
        Map<Id, Id> getContactData = new Map<Id, Id>();
        for (Contact c : [SELECT Id, AccountId FROM Contact WHERE Id IN (SELECT ContactId FROM AccountContactRelation WHERE AccountId = :getAccountID)]) {
          getContactData.put(c.Id, c.AccountId);
        }
        if (getContactData.size() > 0) {
          // Group Member Accounts
          if (retrievalScenario == 'AccAddCtrl_GM_Account') {
            getGMData = [
                SELECT Id, FinServ__PrimaryContact__c, Name, RecordType.Name,
                    ShippingStreet, Postal_Suburb__c, ShippingCity, ShippingState, ShippingPostalCode, ShippingCountry, Postal_Address_Invalid__c,
                    BillingStreet, Business_Suburb__c, BillingCity, BillingState, BillingPostalCode, BillingCountry, Business_Address_Invalid__c
                FROM Account
                WHERE Id IN:getContactData.values()
            ];
          }
          // Group Member Financial Accounts
          if (retrievalScenario == 'AccAddCtrl_GM_FinAccount') {
            getGMData = getAllFinancialAccounts(getContactData.values());
          }
          // Group Member Contacts
          if (retrievalScenario == 'AccAddCtrl_GM_Contact') {
            getGMData = [
                SELECT Id, AccountId, Name, RecordType.Name,
                    OtherStreet, Residential_Suburb__c, OtherCity, OtherState, OtherPostalCode, OtherCountry, Residential_Address_Invalid__c
                FROM Contact
                WHERE Id IN:getContactData.keySet()
            ];
          }
        }
      }
    } catch (Exception e) {
   logUtilityCapture.insertErrorLog(e);
    }

    return getGMData;
  }

  @AuraEnabled
  public static FinServ__FinancialAccount__c[] getAllFinancialAccounts(List<Id> allConAccountIds) {
    List<FinServ__FinancialAccount__c> getFinancialAccounts = new List<FinServ__FinancialAccount__c>();
    try {
      Set<Id> faIds = new Set<Id>();
      for (FinServ__FinancialAccountRole__c rec : [
          SELECT FinServ__FinancialAccount__r.Id
          FROM FinServ__FinancialAccountRole__c
          WHERE FinServ__RelatedAccount__c IN:allConAccountIds AND
          FinServ__Role__c = 'Primary Life Insured' AND
          FinServ__FinancialAccount__r.Product_System_Code__c = 'TZ'
      ]) {
        faIds.add(rec.FinServ__FinancialAccount__r.Id);
      }
      List<FinServ__FinancialAccount__c> financialAccounts = [
          SELECT Id, Name, FinServ__PrimaryOwner__c, FinServ__ProductName__r.Name, FinServ__Status__c,
              Product_System__c, Product_System_Code__c,
              FinServ__FinancialAccountNumber__c, FinServ__Address1__c,
              FinServ__City__c, FinServ__State__c, Suburb__c,
              FinServ__Country__c, FinServ__PostalCode__c,
              /*Address_Invalid__c SFP-35055*/ Address_WADI__c, FinServ__FinancialAccountType__c,
              Address_DPID__c
          FROM FinServ__FinancialAccount__c
          WHERE (AMP_Product__c = true and (FinServ__PrimaryOwner__c IN:allConAccountIds OR FinServ__JointOwner__c IN:allConAccountIds))
          OR Id IN:faIds
      ] ;

      List<FinServ__FinancialAccount__c> active = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> pending = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> lodged = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> closed = new List<FinServ__FinancialAccount__c>();
      List<FinServ__FinancialAccount__c> other = new List<FinServ__FinancialAccount__c>();
         system.debug('finAct.FinServ__Status__c:1:'+financialAccounts);
      for (FinServ__FinancialAccount__c finAct : financialAccounts) {
          system.debug('finAct.FinServ__Status__c::'+finAct.FinServ__Status__c);
        if (finAct.FinServ__Status__c == 'Active') {
          active.add(finAct);
        } else if (finAct.FinServ__Status__c == 'Pending') {
          pending.add(finAct);
        } else if (finAct.FinServ__Status__c == 'Lodged') {
          lodged.add(finAct);
        } else if (finAct.FinServ__Status__c == 'Closed') {
          closed.add(finAct);
        } else {
          other.add(finAct);
        }
      }
      getFinancialAccounts.addAll(active);
      getFinancialAccounts.addAll(other);
      getFinancialAccounts.addAll(pending);
      getFinancialAccounts.addAll(lodged);
      getFinancialAccounts.addAll(closed);
    } catch (Exception e) {
      logUtilityCapture.insertErrorLog(e);
    }
    return getFinancialAccounts;
  }


  @AuraEnabled
  public static void updateAllGroupAddresses(Id householdID, String street, String suburb, String city, String state, String postcode, String country, Boolean invalid, string DPID) {
    try {
      Set<Id> getGMContactIDs = new Set<Id>();
      Set<Id> getGMAccountIDs = new Set<Id>();
      Set<Id> getGMFinAccIDs = new Set<Id>();
      List<Contact> gmAllContacts = new List<Contact>();
      List<Contact> setContactListForUpd = new List<Contact>();
      List<Account> gmAllAccounts = new List<Account>();
      List<Account> setAccountListForUpd = new List<Account>();
      List<FinServ__FinancialAccount__c> getAllFAAccounts = new List<FinServ__FinancialAccount__c>();
      List<AccountContactRelation> acrList = [SELECT Id, ContactId FROM AccountContactRelation WHERE AccountId = :householdID];
      List<Boolean> updateResidentialAddrValidity = new List<Boolean>();
      List<Boolean> updatePostBusAddrValidity = new List<Boolean>();
      Integer count = 0;
	system.debug('acrList.size()::'+acrList.size());
      if (acrList.size() > 0) {
        for (AccountContactRelation acr : acrList) {
          getGMContactIDs.add(acr.ContactId);
        }
        if (getGMContactIDs.size() > 0) {
          gmAllContacts = [
              SELECT AccountId, Account.RecordType.Name, OtherStreet, Residential_Suburb__c, OtherCity, OtherState, OtherPostalCode, OtherCountry,
                  Residential_Address_Invalid__c, Residential_Address_Delivery_Point_Id__c
              FROM Contact
              WHERE Id IN:getGMContactIDs
          ];
          for (Contact c : gmAllContacts) {
            getGMAccountIDs.add(c.AccountId);
          }
          if (getGMAccountIDs.size() > 0) {
            gmAllAccounts = [
                SELECT Id, Name, RecordType.Name, Postal_Address_Delivery_Point_Id__c, Business_Delivery_Point_Id__c,
                    FinServ__PrimaryContact__c, BillingCity, BillingCountry, BillingPostalCode, BillingState, BillingStreet,
                    Business_Suburb__c, Business_Address_Invalid__c, Business_Addressee_Name__c, ShippingCity, ShippingCountry,
                    ShippingPostalCode, ShippingState, ShippingStreet, Postal_Suburb__c, Postal_Address_Invalid__c,
                    Postal_Addressee_Name__c
                FROM Account
                WHERE Id IN:getGMAccountIDs
            ];

            if (gmAllContacts.size() > 0 || gmAllAccounts.size() > 0) {
              // Group Member Contacts
              for (Contact c : gmAllContacts) {
                if (String.valueOf(c.Account.RecordType.Name).equals('Individual') ||
                    String.valueOf(c.Account.RecordType.Name).equals('Associated Person')) {

                  // * Residential Address
                  if (c.OtherStreet != street) {
                    c.OtherStreet = street;
                    updateResidentialAddrValidity.add(true);
                  }
                  if (c.Residential_Suburb__c != suburb) {
                    c.Residential_Suburb__c = suburb;
                    updateResidentialAddrValidity.add(true);
                  }
                  if (c.OtherCity != city) {
                    c.OtherCity = city;
                    updateResidentialAddrValidity.add(true);
                  }
                  if (c.OtherState != state) {
                    c.OtherState = state;
                    updateResidentialAddrValidity.add(true);
                  }
                  if (c.OtherPostalCode != postcode) {
                    c.OtherPostalCode = postcode;
                    updateResidentialAddrValidity.add(true);
                  }
